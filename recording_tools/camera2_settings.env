CAMERA_NAME=camera2
VIDEO_DEVICE=/dev/v4l/by-path/platform-3610000.usb-usb-0:2.2:1.0-video-index0
IMAGE_TOPIC=/recording/camera2/image_raw

WIDTH=1920
HEIGHT=1080
FPS=10
DURATION=7

PIXEL_FORMAT=YUYV
OUTPUT_ENCODING=rgb8

POWER_LINE_FREQUENCY=2
AUTO_EXPOSURE=1
EXPOSURE=500
GAIN=32
BRIGHTNESS=0
CONTRAST=34
SATURATION=45
SHARPNESS=26

OUTPUT_DIR=/home/airobot/recordings
